# Backend — local development (npm run start:dev), Postgres/Redis on localhost or Docker ports
NODE_ENV=development
PORT=3000

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001
FRONTEND_URL=http://localhost:3001
AUTH_COOKIE_SECURE=false

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=food_ordering

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=dev-secret-key-change-for-shared-env
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=dev-refresh-secret-change-for-shared-env
JWT_REFRESH_EXPIRATION=7d

MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

FACE_MATCH_THRESHOLD=0.45
FACE_AMBIGUITY_GAP=0.02

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@lotfood.ru
