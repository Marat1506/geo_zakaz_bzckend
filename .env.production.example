# Backend — production process (NODE_ENV=production), e.g. Node on VPS or PM2
# When using root docker-compose, these are injected by Compose instead of this file.

NODE_ENV=production
PORT=3000

ALLOWED_ORIGINS=https://lotfood.ru,https://www.lotfood.ru
FRONTEND_URL=https://lotfood.ru
AUTH_COOKIE_SECURE=true

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG
DB_NAME=food_ordering

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=CHANGE_ME_LONG_RANDOM
JWT_REFRESH_EXPIRATION=7d

MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

FACE_MATCH_THRESHOLD=0.45
FACE_AMBIGUITY_GAP=0.02

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@lotfood.ru
